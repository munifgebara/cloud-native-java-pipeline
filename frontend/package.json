{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --base-href /app/ && cp -r ../src/main/resources/static/app/browser/* ../src/main/resources/static/app/ && rm -rf ../src/main/resources/static/app/browser",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "e2e": "playwright test"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "overrides": {
    "@angular/build": {
      "undici": "^7.28.0"
    }
  },
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@primeuix/themes": "^2.0.3",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.17",
    "@angular/cli": "^21.2.17",
    "@angular/compiler-cli": "^21.2.17",
    "@playwright/test": "^1.61.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
