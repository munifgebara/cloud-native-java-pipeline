# Copy to /etc/stella-backup/backup.env on Gimli and adjust local values.
# Do not commit the real file with credentials or private key material.

STELLA_KUBECTL_CMD="sudo k3s kubectl"
STELLA_MC_CMD="/usr/local/bin/mcli"
STELLA_BACKUP_ROOT="/var/backups/stella"
STELLA_BACKUP_WORK_ROOT="/tmp/stella-backup"

# Keep the default narrow. Add monitoring/logging only when those namespaces exist
# and you want their resources included in the Stella operational backup.
STELLA_BACKUP_NAMESPACES="platform"

STELLA_POSTGRES_NAMESPACE="platform"
STELLA_POSTGRES_WORKLOAD="statefulset/postgres"
STELLA_POSTGRES_USER="postgres"
STELLA_POSTGRES_DATABASES="stella_dev stella_staging stella_prod keycloak"

STELLA_MINIO_NAMESPACE="platform"
STELLA_MINIO_SERVICE_URL="http://127.0.0.1:19000"
STELLA_MINIO_SECRET_NAME="minio-secret"
STELLA_MINIO_ACCESS_KEY_FIELD="MINIO_ROOT_USER"
STELLA_MINIO_SECRET_KEY_FIELD="MINIO_ROOT_PASSWORD"

# Example: gdrive:StellaBackups
# Prefer an rclone crypt remote when possible, or keep STELLA_BACKUP_AGE_RECIPIENT enabled.
STELLA_BACKUP_RCLONE_REMOTE="gdrive:StellaBackups"
STELLA_BACKUP_REQUIRE_UPLOAD="true"
STELLA_BACKUP_RETENTION_AGE="30d"

# Public age recipient. Keep the private identity outside git, for example:
# /etc/stella-backup/age-key.txt
STELLA_BACKUP_AGE_RECIPIENT="age1replace_with_public_recipient"
STELLA_BACKUP_AGE_IDENTITY="/etc/stella-backup/age-key.txt"
